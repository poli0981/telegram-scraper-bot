# ─── Required ───────────────────────────────────────────────────

# Telegram bot token from @BotFather
BOT_TOKEN=1234567890:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# GitHub fine-grained PAT with Actions:write + Contents:read on the
# Steam + itch tracker repos. Classic PAT also works (scope: workflow).
GH_PAT=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Comma-separated Telegram user IDs allowed to use the bot.
# Get yours from @userinfobot.
ALLOWED_USER_IDS=123456789,987654321

# Repos that own the bot-ingest.yml workflow
STEAM_REPO=poli0981/steam-f2p-tracker
ITCH_REPO=poli0981/itchio-f2p-tracker

# ─── Optional ───────────────────────────────────────────────────

# Workflow filename in both repos (.github/workflows/<file>)
# Default: bot-ingest.yml
WORKFLOW_FILE=bot-ingest.yml

# Branch to dispatch on. Default: main
WORKFLOW_REF=main

# Persistence file path (PicklePersistence). Default: ./state/bot.pickle
PERSISTENCE_PATH=./state/bot.pickle

# Per-user rate limit: max dispatches per window. Default: 3
RATE_LIMIT_USER_MAX=3

# Per-user rate limit window in seconds. Default: 1800 (30 min)
RATE_LIMIT_USER_WINDOW=1800

# Global rate limit: max dispatches per window. Default: 10
RATE_LIMIT_GLOBAL_MAX=10

# Global rate limit window in seconds. Default: 3600 (1 hour)
RATE_LIMIT_GLOBAL_WINDOW=3600

# Max links per dispatch. Default: 100
MAX_LINKS_PER_DISPATCH=100

# Log level: DEBUG, INFO, WARNING, ERROR. Default: INFO
LOG_LEVEL=INFO
